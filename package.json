{
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.yaml": [
      "prettier --write"
    ]
  }
}
